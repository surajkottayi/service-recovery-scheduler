# Keep the build context small and reproducible: any prior host build
# artefacts, VCS metadata, and editor droppings would only bloat the layer
# cache and risk leaking absolute host paths into the image.
build/
.git/
.github/
.vscode/
.idea/
**/*.o
**/*.a
**/*.so
**/*.so.*
**/*.gcda
**/*.gcno
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/Makefile
Dockerfile
.dockerignore
